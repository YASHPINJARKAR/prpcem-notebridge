# ============================================================
# PRPCEM NoteBridge – Environment Variables Template
# Copy this file to .env and fill in real values
# NEVER commit .env to GitHub
# ============================================================

# ── Server ──────────────────────────────────────────────────
PORT=5000
NODE_ENV=production

# ── MongoDB Atlas (use your Atlas connection string on Render)
MONGO_URI=mongodb+srv://<username>:<password>@<cluster>.mongodb.net/notebridge

# ── JWT ─────────────────────────────────────────────────────
JWT_SECRET=your_super_long_random_secret_here
JWT_EXPIRE=7d

# ── Email (Gmail App Password) ───────────────────────────────
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=prpcem.notebridge.ac@gmail.com
EMAIL_PASS=your_gmail_app_password_here
EMAIL_FROM=PRPCEM NoteBridge <prpcem.notebridge.ac@gmail.com>

# ── Frontend URL (set to your Render static site URL) ────────
CLIENT_URL=https://notebridge-frontend.onrender.com

# ── File Upload ──────────────────────────────────────────────
MAX_FILE_SIZE_MB=50

# ── Cloudinary (For premium file storage on Render) ──────────
CLOUDINARY_CLOUD_NAME=your_cloudinary_cloud_name_here
CLOUDINARY_API_KEY=your_cloudinary_api_key_here
CLOUDINARY_API_SECRET=your_cloudinary_api_secret_here

